---
interface Props {
  slug: string;
  title: string;
  description: string;
  tags: string[];
  image: string;
  featured?: boolean;
}

const { slug, title, description, tags, image, featured } = Astro.props;
---

<article class="group relative flex flex-col overflow-hidden rounded-[var(--radius-card)] border border-[var(--color-border)] bg-[var(--color-surface)] transition-all duration-300 hover:border-[var(--color-accent)]/40 hover:-translate-y-1">
  <a href={`/portfolio/${slug}`} class="block overflow-hidden aspect-video bg-[var(--color-surface-2)]">
    {image ? (
      <img
        src={image}
        alt={title}
        loading="lazy"
        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
      />
    ) : (
      <div class="h-full w-full flex items-center justify-center text-[var(--color-muted)]">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="2"/>
          <circle cx="8.5" cy="8.5" r="1.5"/>
          <path d="m21 15-5-5L5 21"/>
        </svg>
      </div>
    )}
    {featured && (
      <span class="absolute top-3 left-3 rounded-full bg-[var(--color-accent)] px-2.5 py-1 text-xs font-semibold text-white">
        Destacado
      </span>
    )}
  </a>

  <div class="flex flex-1 flex-col gap-3 p-5">
    <a href={`/portfolio/${slug}`} class="hover:text-[var(--color-accent)] transition-colors">
      <h3 class="text-base font-semibold leading-snug">{title}</h3>
    </a>
    <p class="text-sm text-[var(--color-muted)] line-clamp-2 flex-1">{description}</p>

    <div class="flex flex-wrap gap-1.5 mt-1">
      {tags.slice(0, 4).map((tag) => (
        <span class="rounded-full border border-[var(--color-border)] px-2.5 py-0.5 text-xs text-[var(--color-muted)]">
          {tag}
        </span>
      ))}
    </div>
  </div>
</article>
