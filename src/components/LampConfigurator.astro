---
// Configurador de la lámpara TesseraLamp.
// Las imágenes de cada pieza son PNG 800x800 con fondo transparente, renderizadas
// desde la misma cámara, de modo que se superponen por z-index para formar la lámpara.

type Part = {
  key: 'pantalla' | 'tapa' | 'cuerpo';
  label: string;
  z: number;
  colors: string[];
};

const PARTS: Part[] = [
  { key: 'pantalla', label: 'Pantalla', z: 30, colors: ['Azul', 'Rojo', 'Verde', 'Amarillo', 'Morado', 'Naranja'] },
  { key: 'tapa',     label: 'Tapa',     z: 20, colors: ['Azul', 'Rojo', 'Verde', 'Amarillo', 'Morado', 'Naranja'] },
  { key: 'cuerpo',   label: 'Cuerpo',   z: 10, colors: ['Blanco'] },
];

const SWATCH: Record<string, string> = {
  Azul: '#2f5fd6',
  Rojo: '#c5202b',
  Verde: '#2e9e3f',
  Amarillo: '#d9a221',
  Morado: '#7b3fc4',
  Naranja: '#e0701a',
  Blanco: '#e8e8e8',
};

const DEFAULTS: Record<Part['key'], string> = {
  pantalla: 'Azul',
  tapa: 'Azul',
  cuerpo: 'Blanco',
};

const cap = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);
const src = (part: string, color: string) =>
  `/images/tessera/TesseraLamp_${cap(part)}_${color}.png`;

// Capas ordenadas de abajo (cuerpo) hacia arriba (pantalla) para el apilado visual.
const layers = [...PARTS].sort((a, b) => a.z - b.z);
---

<div class="configurator">
  <!-- Previsualización: las tres piezas superpuestas -->
  <div class="preview" role="img" aria-label="Previsualización de la lámpara TesseraLamp">
    {layers.map((part) => (
      <img
        data-layer={part.key}
        src={src(part.key, DEFAULTS[part.key])}
        alt=""
        aria-hidden="true"
        style={`z-index:${part.z}`}
        decoding="async"
        draggable="false"
      />
    ))}
  </div>

  <!-- Selectores: un grupo por pieza -->
  <div class="selectors">
    {PARTS.map((part) => (
      <fieldset class="part" role="radiogroup" aria-label={`Color de ${part.label.toLowerCase()}`}>
        <legend>{part.label}</legend>
        <div class="swatches">
          {part.colors.map((color) => (
            <button
              type="button"
              class="swatch"
              data-part={part.key}
              data-color={color}
              role="radio"
              aria-checked={DEFAULTS[part.key] === color ? 'true' : 'false'}
              aria-label={color}
              title={color}
              style={`--swatch:${SWATCH[color]}`}
            >
              <span class="dot"></span>
            </button>
          ))}
        </div>
      </fieldset>
    ))}
  </div>
</div>

<style>
  .configurator {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    align-items: center;
    width: 100%;
  }

  .preview {
    position: relative;
    width: 100%;
    max-width: 520px;
    aspect-ratio: 1 / 1;
  }

  .preview img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    user-select: none;
    -webkit-user-drag: none;
  }

  .selectors {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem 2.5rem;
    width: 100%;
    max-width: 600px;
  }

  .part {
    border: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .part legend {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
    padding: 0;
  }

  .swatches {
    display: flex;
    gap: 0.6rem;
  }

  .swatch {
    width: 2.25rem;
    height: 2.25rem;
    padding: 0;
    border-radius: 9999px;
    border: 2px solid var(--color-border);
    background: transparent;
    cursor: pointer;
    display: grid;
    place-items: center;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }

  .swatch:hover {
    transform: scale(1.08);
  }

  .swatch:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .swatch .dot {
    width: 1.4rem;
    height: 1.4rem;
    border-radius: 9999px;
    background: var(--swatch);
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.25);
  }

  .swatch[aria-checked='true'] {
    border-color: var(--color-accent);
  }
</style>

<script>
  const cap = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);
  const srcFor = (part: string, color: string) =>
    `/images/tessera/TesseraLamp_${cap(part)}_${color}.png`;

  document.querySelectorAll<HTMLButtonElement>('.swatch').forEach((btn) => {
    btn.addEventListener('click', () => {
      const part = btn.dataset.part!;
      const color = btn.dataset.color!;

      // Cambia solo la capa de esta pieza, sin recargar.
      const layer = document.querySelector<HTMLImageElement>(`[data-layer="${part}"]`);
      if (layer) layer.src = srcFor(part, color);

      // Estado visual: marca el swatch activo dentro de su grupo.
      btn
        .closest('[role="radiogroup"]')
        ?.querySelectorAll<HTMLButtonElement>('.swatch')
        .forEach((s) => s.setAttribute('aria-checked', s === btn ? 'true' : 'false'));
    });
  });

  // Precarga todas las combinaciones para que el cambio sea instantáneo.
  const PRELOAD: Record<string, string[]> = {
    pantalla: ['Azul', 'Rojo', 'Verde', 'Amarillo', 'Morado', 'Naranja'],
    tapa: ['Azul', 'Rojo', 'Verde', 'Amarillo', 'Morado', 'Naranja'],
    cuerpo: ['Blanco'],
  };
  for (const [part, colors] of Object.entries(PRELOAD)) {
    for (const color of colors) {
      const img = new Image();
      img.src = srcFor(part, color);
    }
  }
</script>
