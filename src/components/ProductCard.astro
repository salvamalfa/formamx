---
interface Props {
  slug: string;
  title: string;
  description: string;
  price: string;
  image: string;
  category: string;
  available?: boolean;
  featured?: boolean;
}

const { slug, title, description, price, image, category, available = true, featured } = Astro.props;
---

<article class="group flex flex-col overflow-hidden rounded-[var(--radius-card)] border border-[var(--color-border)] bg-[var(--color-surface)] transition-all duration-300 hover:border-[var(--color-accent)]/40 hover:-translate-y-1">
  <a href={`/store/${slug}`} class="block overflow-hidden aspect-square bg-[var(--color-surface-2)] relative">
    {image ? (
      <img
        src={image}
        alt={title}
        loading="lazy"
        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
      />
    ) : (
      <div class="h-full w-full flex items-center justify-center text-[var(--color-muted)]">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
      </div>
    )}
    {featured && (
      <span class="absolute top-3 left-3 rounded-full bg-[var(--color-accent)] px-2.5 py-1 text-xs font-semibold text-white">
        Destacado
      </span>
    )}
    {!available && (
      <div class="absolute inset-0 flex items-center justify-center bg-[var(--color-bg)]/70">
        <span class="rounded-full bg-[var(--color-surface)] border border-[var(--color-border)] px-3 py-1.5 text-xs font-semibold text-[var(--color-muted)]">
          Agotado
        </span>
      </div>
    )}
  </a>

  <div class="flex flex-1 flex-col gap-2 p-5">
    <span class="text-xs font-medium text-[var(--color-accent)] uppercase tracking-wider">{category}</span>
    <a href={`/store/${slug}`} class="hover:text-[var(--color-accent)] transition-colors">
      <h3 class="text-base font-semibold leading-snug">{title}</h3>
    </a>
    <p class="text-sm text-[var(--color-muted)] line-clamp-2 flex-1">{description}</p>
    <div class="mt-3 flex items-center justify-between">
      <span class="text-lg font-bold text-[var(--color-text)]">{price}</span>
      <a
        href={`/store/${slug}`}
        class="rounded-[var(--radius-btn)] bg-[var(--color-accent)] px-4 py-1.5 text-sm font-semibold text-white transition-colors hover:bg-[var(--color-accent-hover)]"
      >
        Ver más
      </a>
    </div>
  </div>
</article>
