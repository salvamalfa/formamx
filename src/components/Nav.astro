---
const pathname = Astro.url.pathname;

const links = [
  { href: '/',          label: 'Inicio' },
  { href: '/portfolio', label: 'Work' },
  { href: '/store',     label: 'Tienda' },
  { href: '/about',     label: 'About' },
  { href: '/contact',   label: 'Contacto' },
];

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header class="sticky top-0 z-50 border-b border-[var(--color-border)] bg-[var(--color-bg)]/90 backdrop-blur-sm">
  <nav class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
    <a href="/" class="text-lg font-bold tracking-tight hover:text-[var(--color-accent)] transition-colors">
      formamx<span class="text-[var(--color-accent)]">.</span>
    </a>

    <ul class="hidden items-center gap-6 md:flex">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'text-sm font-medium transition-colors',
              isActive(href)
                ? 'text-[var(--color-accent)]'
                : 'text-[var(--color-muted)] hover:text-[var(--color-text)]',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile menu button -->
    <button
      id="menu-toggle"
      aria-label="Abrir menú"
      class="flex flex-col gap-1.5 md:hidden"
    >
      <span class="h-0.5 w-6 bg-[var(--color-text)] rounded"></span>
      <span class="h-0.5 w-6 bg-[var(--color-text)] rounded"></span>
      <span class="h-0.5 w-4 bg-[var(--color-text)] rounded"></span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-[var(--color-border)] md:hidden">
    <ul class="flex flex-col px-6 py-4 gap-4">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'text-sm font-medium block transition-colors',
              isActive(href)
                ? 'text-[var(--color-accent)]'
                : 'text-[var(--color-muted)] hover:text-[var(--color-text)]',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
