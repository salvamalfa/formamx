---
import BaseLayout from '../layouts/BaseLayout.astro';
import LampConfigurator from '../components/LampConfigurator.astro';
---

<BaseLayout title="TesseraLamp" description="Personaliza tu lámpara TesseraLamp: elige el color de cada pieza y míralo al instante.">
  <main class="min-h-screen flex flex-col items-center justify-center gap-10 px-6 py-16">
    <header class="flex flex-col items-center gap-3 text-center">
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight">TesseraLamp</h1>
      <p class="max-w-md text-sm sm:text-base text-[var(--color-muted)]">
        Personaliza tu lámpara: elige el color de cada pieza.
      </p>
    </header>

    <LampConfigurator />
  </main>
</BaseLayout>
